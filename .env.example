APP_NAME=CyberGuard
APP_ENV=local
APP_KEY=base64:REPLACEME_RUN_php_artisan_key_generate
APP_DEBUG=true
APP_TIMEZONE=Africa/Porto-Novo
APP_URL=http://localhost:8000

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ── BASE DE DONNÉES ────────────────────────────
# Option 1: SQLite (recommandé pour démarrage rapide)
#DB_CONNECTION=sqlite
# Le fichier sera créé automatiquement : database/database.sqlite

# Option 2: MySQL
 DB_CONNECTION=mysql
 DB_HOST=127.0.0.1
 DB_PORT=3306
 DB_DATABASE=cyberguard
 DB_USERNAME=root
 DB_PASSWORD=

# ── SESSION / CACHE ───────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database

# ── CYBERGUARD ────────────────────────────────
ALARM_THRESHOLD=high
DETECTION_INTERVAL=5
DEMO_AUTO_ATTACKS=true
DEMO_ATTACK_RATE=30
HONEYPOT_ENABLED=true
HONEYPOT_LOG_ALL=true
GEO_PROVIDER=local

VITE_APP_NAME="${APP_NAME}"
